NODE_ENV=development
PORT=3001

# Railway provides this automatically
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT — use a long random string (32+ characters)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Resend — get your API key at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=CarParts Finder

# Cloudflare R2 — create bucket and API token at dash.cloudflare.com
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=carparts-uploads
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# CORS — your frontend URL
FRONTEND_URL=http://localhost:5173

# Admin email for contact form notifications
ADMIN_EMAIL=admin@yourdomain.com
